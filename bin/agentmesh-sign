#!/bin/bash
# agentmesh-sign — Sign and verify operations
# Usage: agentmesh-sign sign <file>
#        agentmesh-sign verify <file> <machine>
set -euo pipefail

HOSTNAME=$(hostname)
KEYS_DIR="$HOME/.agentmesh/keys"
MEMORY_DIR="${AGENTMESH_MEMORY_DIR:-}"

if [ -z "$MEMORY_DIR" ]; then
    CONFIG_FILE="$HOME/.agentmesh/config.json"
    if [ -f "$CONFIG_FILE" ]; then
        MEMORY_DIR=$(python3 -c "import json; print(json.load(open('$CONFIG_FILE'))['memory_dir'])")
    else
        SANITIZED_HOME=$(echo "$HOME" | sed 's|/|-|g')
        MEMORY_DIR="$HOME/.claude/projects/$SANITIZED_HOME/memory"
        [ ! -d "$MEMORY_DIR" ] && MEMORY_DIR="$HOME/.claude/projects/$(echo "$SANITIZED_HOME" | sed 's|^-||')/memory"
    fi
fi

CMD="${1:-}"

case "$CMD" in
    sign)
        FILE="${2:?Usage: agentmesh-sign sign <file>}"
        [ ! -f "$KEYS_DIR/private.pem" ] && { echo "ERROR: No private key. Run 'agentmesh-node register' first."; exit 1; }

        SIG_FILE="${FILE}.sig"
        openssl pkeyutl -sign -inkey "$KEYS_DIR/private.pem" -in "$FILE" -out "$SIG_FILE" 2>/dev/null
        echo "Signed: $SIG_FILE"
        ;;

    verify)
        FILE="${2:?Usage: agentmesh-sign verify <file> <machine>}"
        MACHINE="${3:?Usage: agentmesh-sign verify <file> <machine>}"

        PUBKEY="$MEMORY_DIR/machines/$MACHINE/public.pem"
        [ ! -f "$PUBKEY" ] && { echo "ERROR: No public key for $MACHINE"; exit 1; }

        SIG_FILE="${FILE}.sig"
        [ ! -f "$SIG_FILE" ] && { echo "ERROR: No signature file: $SIG_FILE"; exit 1; }

        if openssl pkeyutl -verify -pubin -inkey "$PUBKEY" -in "$FILE" -sigfile "$SIG_FILE" 2>/dev/null; then
            echo "✅ Signature valid (from $MACHINE)"
        else
            echo "❌ Signature INVALID or not from $MACHINE"
            exit 1
        fi
        ;;

    *)
        echo "Usage: agentmesh-sign [sign|verify] [args]"
        ;;
esac
