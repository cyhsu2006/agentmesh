#!/bin/bash
# agentmesh-join — Join an existing AgentMesh network
# Usage: agentmesh join <token>
set -euo pipefail

HOSTNAME=$(hostname)
CONFIG_DIR="$HOME/.agentmesh"
RCLONE_CONF="$CONFIG_DIR/rclone.conf"

if [ -z "${1:-}" ]; then
    echo "Usage: agentmesh join <token>"
    echo ""
    echo "Get the token from the machine that ran 'agentmesh init'."
    exit 1
fi

TOKEN="$1"

echo "=== AgentMesh Join ==="
echo "Joining mesh on: $HOSTNAME"
echo ""

# Check dependencies
for cmd in rclone claude python3; do
    if ! command -v "$cmd" &>/dev/null; then
        echo "ERROR: '$cmd' is required but not installed."
        exit 1
    fi
done

# Create config directory
mkdir -p "$CONFIG_DIR"

# Step 1: Decode token
echo "--- Step 1: Decoding Token ---"
TOKEN_DATA=$(python3 -c "
import json, base64, sys
try:
    data = json.loads(base64.urlsafe_b64decode('$TOKEN').decode())
    print(json.dumps(data))
except Exception as e:
    print(f'ERROR: Invalid token - {e}', file=sys.stderr)
    sys.exit(1)
")

MESH_ID=$(echo "$TOKEN_DATA" | python3 -c "import json,sys; print(json.load(sys.stdin)['mesh_id'])")
CRYPT_PASSWORD=$(echo "$TOKEN_DATA" | python3 -c "import json,sys; print(json.load(sys.stdin)['crypt_password'])")
CRYPT_PASSWORD2=$(echo "$TOKEN_DATA" | python3 -c "import json,sys; print(json.load(sys.stdin)['crypt_password2'])")
CLOUD_PATH=$(echo "$TOKEN_DATA" | python3 -c "import json,sys; print(json.load(sys.stdin)['cloud_path'])")
CREATED_BY=$(echo "$TOKEN_DATA" | python3 -c "import json,sys; print(json.load(sys.stdin)['created_by'])")

echo "✓ Token decoded."
echo "  Mesh ID: $MESH_ID"
echo "  Created by: $CREATED_BY"
echo ""

# Step 2: Configure Google Drive
echo "--- Step 2: Google Drive Setup ---"
if rclone listremotes --config "$RCLONE_CONF" 2>/dev/null | grep -q "^agentmesh-base:"; then
    echo "Google Drive remote already exists."
    read -p "Reconfigure? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        rclone config delete agentmesh-base --config "$RCLONE_CONF" 2>/dev/null || true
        rclone config create agentmesh-base drive --config "$RCLONE_CONF"
    fi
else
    echo "Setting up Google Drive access..."
    echo "A browser window will open for authentication."
    echo "(Use the SAME Google account as the init machine)"
    echo ""
    rclone config create agentmesh-base drive --config "$RCLONE_CONF"
fi

# Test connection
echo "Testing Google Drive connection..."
if ! rclone lsd agentmesh-base: --config "$RCLONE_CONF" &>/dev/null; then
    echo "ERROR: Cannot connect to Google Drive."
    exit 1
fi
echo "✓ Google Drive connected."
echo ""

# Step 3: Setup encryption with shared keys
echo "--- Step 3: Encryption Setup ---"
rclone config delete agentmesh --config "$RCLONE_CONF" 2>/dev/null || true
rclone config create agentmesh crypt \
    remote="agentmesh-base:$CLOUD_PATH" \
    password="$CRYPT_PASSWORD" \
    password2="$CRYPT_PASSWORD2" \
    --config "$RCLONE_CONF"

# Verify we can read the mesh
echo "Verifying mesh access..."
if rclone cat "agentmesh:mesh.json" --config "$RCLONE_CONF" &>/dev/null; then
    echo "✓ Mesh verified — encryption keys match."
else
    echo "ERROR: Cannot read mesh data. Token may be invalid or wrong Google account."
    exit 1
fi
echo ""

# Step 4: Setup local environment
echo "--- Step 4: Local Environment Setup ---"
CREATED_AT=$(date -Iseconds)

# Detect memory directory
SANITIZED_HOME=$(echo "$HOME" | sed 's|/|-|g; s|^-||')
MEMORY_DIR="$HOME/.claude/projects/$SANITIZED_HOME/memory"
if [ ! -d "$MEMORY_DIR" ]; then
    FOUND=$(find "$HOME/.claude/projects" -maxdepth 2 -name "memory" -type d 2>/dev/null | head -1)
    if [ -n "$FOUND" ]; then
        MEMORY_DIR="$FOUND"
    else
        mkdir -p "$MEMORY_DIR"
    fi
fi

# Save local config
cat > "$CONFIG_DIR/config.json" << JSONEOF
{
  "hostname": "$HOSTNAME",
  "mesh_id": "$MESH_ID",
  "memory_dir": "$MEMORY_DIR",
  "rclone_conf": "$RCLONE_CONF",
  "remote": "agentmesh",
  "sync_interval_min": 60,
  "joined_at": "$CREATED_AT",
  "joined_from": "$CREATED_BY"
}
JSONEOF

# Create machine directory
mkdir -p "$MEMORY_DIR/machines/$HOSTNAME"
mkdir -p "$MEMORY_DIR/broadcasts"
mkdir -p "$MEMORY_DIR/tasks"

# Install scripts to ~/bin
mkdir -p "$HOME/bin"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
for script in "$SCRIPT_DIR"/agentmesh*; do
    [ -f "$script" ] || continue
    cp "$script" "$HOME/bin/"
    chmod +x "$HOME/bin/$(basename "$script")"
done
echo "✓ Scripts installed to ~/bin/"

# Setup cron
CRON_CMD="0 * * * * $HOME/bin/agentmesh sync full >> /tmp/agentmesh.log 2>&1"
if crontab -l 2>/dev/null | grep -q "agentmesh sync"; then
    echo "✓ Cron already configured."
else
    (crontab -l 2>/dev/null || true; echo "$CRON_CMD") | crontab -
    echo "✓ Cron job added (hourly sync)."
fi
echo ""

# Step 5: Initial sync — pull everything
echo "--- Step 5: Initial Sync ---"
bash "$HOME/bin/agentmesh" sync pull
echo ""

echo "=== AgentMesh Join Complete ==="
echo "Mesh ID: $MESH_ID"
echo "Hostname: $HOSTNAME"
echo "Memory: $MEMORY_DIR"
echo "Sync: Every hour via cron"
echo ""
echo "You're in the mesh! This machine will sync automatically."
